#!/usr/bin/env bash

set -euo pipefail  # exit при ошибках, undefined vars и pipe-фейлах

echo "======================================"
echo "  Running quality checks before push  "
echo "======================================"

# Переходим в корень проекта (на случай вызова не из root)
cd "$(git rev-parse --show-toplevel)" || exit 1

echo "→ Running detekt..."
./gradlew --no-daemon --stacktrace detekt
detekt_status=$?

if [ $detekt_status -ne 0 ]; then
    echo "❌ Detekt found issues! Fix them before pushing."
    exit 1
fi

echo "→ Running ktlintCheck..."
./gradlew --no-daemon --stacktrace ktlintCheck
ktlint_status=$?

if [ $ktlint_status -ne 0 ]; then
    echo "❌ ktlintCheck failed! Run './gradlew ktlintFormat' to fix style issues."
    exit 1
fi

# Опционально: полный check (включая тесты, androidLint и т.д.)
# echo "→ Running full check..."
# ./gradlew check
# check_status=$?
# if [ $check_status -ne 0 ]; then
#     echo "❌ Full check failed!"
#     exit 1
# fi

echo "✅ All checks passed. Pushing..."
exit 0